# Copiez ce fichier en .env.local (cp .env.local.example .env.local)
# puis remplissez avec les clés de votre projet Supabase Bercail-dev.
# Ne committez jamais .env.local — .gitignore s'en charge déjà.

# Project Settings → General → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJECT-ID.supabase.co

# Project Settings → API Keys → Publishable and secret API keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Clé secrète : JAMAIS de préfixe NEXT_PUBLIC_, jamais utilisée côté
# navigateur. Réservée aux scripts serveur (synchro portail.yt, etc.)
SUPABASE_SECRET_KEY=sb_secret_...
